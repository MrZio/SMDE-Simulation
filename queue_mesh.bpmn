<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_QueueMesh" targetNamespace="http://example.org/queue" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:collaboration id="Collaboration_Mesh">
    <bpmn:participant id="Participant_S1" name="Lane: Station_1 (A/S/c/N/D)" processRef="Process_S1" />
    <bpmn:participant id="Participant_S2" name="Lane: Station_2 (A/S/c/N/D)" processRef="Process_S2" />
    <bpmn:participant id="Participant_S3" name="Lane: Station_3 (A/S/c/N/D)" processRef="Process_S3" />
    <bpmn:messageFlow id="MFlow_S1_S2" name="route_to next in path (instant/with delay)" sourceRef="Event_End_S1" targetRef="Event_Recv_S2" />
    <bpmn:messageFlow id="MFlow_S2_S3" name="route_to next in path (instant/with delay)" sourceRef="Event_End_S2" targetRef="Event_Recv_S3" />
    <bpmn:messageFlow id="MFlow_S3_S1" name="route_to next in path (instant/with delay)" sourceRef="Event_End_S3" targetRef="Event_Recv_S1" />
    <bpmn:textAnnotation id="TextAnnotation_AnyToAny">
      <bpmn:text>Any station can route to any other station. Only representative flows are drawn (S1-&gt;S2, S2-&gt;S3, S3-&gt;S1); the actual successor is the next element of the entity's pre-sampled path.
Representative routing shown. Any station can route to any other; the full path is a random permutation sampled at entity creation (Script Task).</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:collaboration>
  <bpmn:process id="Process_S1" name="Queueing station A/S/c/N/D" isExecutable="false">
    <bpmn:startEvent id="Event_Start_S1" name="External arrival&#10;A=M/D/G">
      <bpmn:outgoing>Flow_S1_a</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Task_SamplePath_S1" name="Sample&#10;random path&#10;(permutation of stations)">
      <bpmn:incoming>Flow_S1_a</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_b</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_Cap_S1" name="Capacity?&#10;N=n || Infinite">
      <bpmn:incoming>Flow_S1_b</bpmn:incoming>
      <bpmn:incoming>Flow_S1_recv</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_ok</bpmn:outgoing>
      <bpmn:outgoing>Flow_S1_lost</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Wait_S1" name="Wait in queue&#10;(D=FIFO/LIFO/SIRO)">
      <bpmn:incoming>Flow_S1_ok</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_c</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Serve_S1" name="Serve (c=C)&#10;S=Exp(mu)/Det/General">
      <bpmn:incoming>Flow_S1_c</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_d</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Next_S1" name="More stations&#10;in path?">
      <bpmn:incoming>Flow_S1_d</bpmn:incoming>
      <bpmn:outgoing>Flow_S1_more</bpmn:outgoing>
      <bpmn:outgoing>Flow_S1_done</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateThrowEvent id="Event_End_S1" name="End service&#10;route to next">
      <bpmn:incoming>Flow_S1_more</bpmn:incoming>
      <bpmn:messageEventDefinition id="MsgThrow_S1" />
    </bpmn:intermediateThrowEvent>
    <bpmn:endEvent id="Event_Exit_S1" name="Exit system&#10;(path done)">
      <bpmn:incoming>Flow_S1_done</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="Event_Recv_S1" name="Routed arrival&#10;(from another station)">
      <bpmn:outgoing>Flow_S1_recv</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_S1" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="Event_Lost_S1" name="Entity lost">
      <bpmn:incoming>Flow_S1_lost</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_S1_a" sourceRef="Event_Start_S1" targetRef="Task_SamplePath_S1" />
    <bpmn:sequenceFlow id="Flow_S1_b" sourceRef="Task_SamplePath_S1" targetRef="Gateway_Cap_S1" />
    <bpmn:sequenceFlow id="Flow_S1_recv" sourceRef="Event_Recv_S1" targetRef="Gateway_Cap_S1" />
    <bpmn:sequenceFlow id="Flow_S1_ok" sourceRef="Gateway_Cap_S1" targetRef="Task_Wait_S1" />
    <bpmn:sequenceFlow id="Flow_S1_lost" name="No (capacity reached)" sourceRef="Gateway_Cap_S1" targetRef="Event_Lost_S1" />
    <bpmn:sequenceFlow id="Flow_S1_c" sourceRef="Task_Wait_S1" targetRef="Task_Serve_S1" />
    <bpmn:sequenceFlow id="Flow_S1_d" sourceRef="Task_Serve_S1" targetRef="Gateway_Next_S1" />
    <bpmn:sequenceFlow id="Flow_S1_more" name="Yes" sourceRef="Gateway_Next_S1" targetRef="Event_End_S1" />
    <bpmn:sequenceFlow id="Flow_S1_done" name="No" sourceRef="Gateway_Next_S1" targetRef="Event_Exit_S1" />
  </bpmn:process>
